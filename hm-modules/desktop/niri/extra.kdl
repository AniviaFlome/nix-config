recent-windows {
    debounce-ms 500
    highlight {
        active-color "#cba6f7"
        urgent-color "#f38ba8"
    }
    previews {
        max-height 480
        max-scale 0.3
    }
}

binds {
    "Mod+M" { maximize-window-to-edges; }
}

blur {
    passes 3
    offset 3
    noise 0.02
    saturation 1.5
}

window-rule {
    match app-id="^kitty$"
    opacity 0.9
    background-effect {
        blur true
        xray true
    }
}
